@{
    ViewData["Title"] = "Agenda de Citas";
    Layout = "_Layout";
}


<div class="p-4" style="background-color: #F3F4F6; min-height: calc(100vh - 60px);">
    @Html.AntiForgeryToken()

    <!-- Calendar Card Container -->
    <div class="card border-0 shadow-sm" style="border-radius: 16px;">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">

            <!-- Left Controls: Prev, Next, Today -->
            <div class="d-flex gap-2 align-items-center order-2 order-md-1">
                <button class="btn btn-light border bg-white px-3 py-1 fw-semibold custom-cal-nav" id="btnPrevMonth">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <button class="btn btn-light border bg-white px-3 py-1 fw-semibold custom-cal-nav" id="btnNextMonth">
                    <i class="fas fa-chevron-right"></i>
                </button>
                <button class="btn btn-light border bg-white px-3 px-md-4 py-1 fw-semibold custom-cal-nav" id="btnToday">
                    Hoy
                </button>
            </div>

            <!-- Center Title -->
            <div class="text-center order-1 order-md-2">
                <small class="text-uppercase fw-bold text-muted mb-1 d-block" style="letter-spacing: 1px; font-size:0.85rem;">Agenda Médica</small>
                <h5 class="mb-0 fw-bold text-dark" id="calendarTitle"></h5>
            </div>

            <!-- Right Controls: View Switcher -->
            <div class="btn-group order-3" role="group">
                <button type="button" class="btn btn-view btn-sm bg-white text-secondary border px-3" id="btnViewMonth">Mes</button>
                <button type="button" class="btn btn-view btn-sm bg-white text-secondary border px-3" id="btnViewWeek">Sem</button>
                <button type="button" class="btn btn-view btn-sm bg-white text-secondary border px-3" id="btnViewDay">Día</button>
            </div>

        </div>
        <div class="card-body p-4 position-relative">
            <div id="fullcalendar-loading" class="position-absolute top-50 start-50 translate-middle text-center" style="z-index: 10;">
                <div class="spinner-border text-primary mb-2" role="status"></div>
                <div class="text-muted small fw-medium">Preparando agenda...</div>
            </div>
            <div id="fullcalendar" style="min-height: 650px; opacity: 0; transition: opacity 0.3s ease;"></div>
        </div>
    </div>

    <!-- Floating Action Button: Agenda de Hoy (QA Expert Optimized) -->
    <button class="btn shadow-lg position-fixed d-flex align-items-center floating-agenda-btn"
        data-bs-toggle="offcanvas" data-bs-target="#agendaHoy">
        <i class="fas fa-calendar-day me-2 fs-5"></i> <span>Ver agenda de hoy</span>
    </button>
</div>

@await Html.PartialAsync("_AgendaShared")

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.14/index.global.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/citas-calendar.css" asp-append-version="true" />
    <style>
        .floating-agenda-btn {
            bottom: 60px; 
            right: 40px; 
            border-radius: 50px; 
            z-index: 1040; 
            padding: 12px 24px; 
            font-weight: 600; 
            background-color: #4F46E5; 
            color: white; 
            border: none; 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .floating-agenda-btn:hover {
            transform: scale(1.05);
            background-color: #4338CA;
            color: white;
        }
        .event-canceled {
            opacity: 0.65;
            background-color: #E1E4E8 !important;
            border-color: #D1D5DB !important;
        }
        .event-canceled .custom-event-title,
        .event-canceled .custom-event-treatment {
            text-decoration: line-through;
            color: #6B7280 !important;
        }
        .event-canceled .custom-event-time {
            color: #9CA3AF !important;
        }
        /* Mobile Refinements for FullCalendar */
        @@media (max-width: 1200px) {
            #fullcalendar {
                min-height: 500px !important;
            }
            .floating-agenda-btn {
                bottom: 20px !important;
                right: 20px !important;
                padding: 10px 18px !important;
                font-size: 0.85rem !important;
            }
        }

        @@media (max-width: 575.98px) {
            #calendar {
                font-size: 0.75rem; /* Smaller font for small screens */
            }
            .fc-event-title {
                font-size: 0.7rem;
                white-space: normal !important;
            }
            .card-header {
                padding: 20px 15px !important;
            }
            #calendarTitle {
                font-size: 1.1rem;
            }
            .floating-agenda-btn span {
                display: none; /* Hide text on mobile, keep icon */
            }
            .floating-agenda-btn {
                width: 50px;
                height: 50px;
                padding: 0 !important;
                justify-content: center;
                border-radius: 50% !important;
            }
            .floating-agenda-btn i {
                margin: 0 !important;
            }
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@@6.1.14/index.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@fullcalendar/core@@6.1.14/locales/es.global.min.js"></script>
    <script src="~/js/citas-calendar.js" asp-append-version="true"></script>
}
