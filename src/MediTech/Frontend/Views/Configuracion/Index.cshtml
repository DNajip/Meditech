@model MediTech.Backend.Models.ConfiguracionMoneda
@{
    ViewData["Title"] = "Configuración del Sistema";
    var tasaActiva = ViewBag.TasaActiva as MediTech.Backend.Models.TasaCambio;
    var historial = ViewBag.Historial as List<MediTech.Backend.Models.TasaCambio>;
    var monedas = ViewBag.Monedas as List<MediTech.Backend.Models.Moneda>;
    var usuarios = ViewBag.Usuarios as List<MediTech.Backend.Models.Usuario>;
    var todosModulos = ViewBag.TodosModulos as List<MediTech.Backend.Models.Modulo>;
    var roles = ViewBag.Roles as List<MediTech.Backend.Models.Role>;
}
@Html.AntiForgeryToken()

<div class="row mb-4">
    <div class="col-12">
        <h2 class="fw-bold"><i class="fas fa-cog me-2 text-primary"></i>Configuración de Sistema</h2>
        <p class="text-muted">Gestión de moneda, usuarios y permisos del sistema.</p>
    </div>
</div>

<div class="accordion border-0 shadow-sm" id="configAccordion">
    
    <!-- SECCIÓN 1: ADMINISTRACIÓN DE MONEDA Y TASA -->
    <div class="accordion-item border-0 mb-3 rounded-3 overflow-hidden shadow-sm">
        <h2 class="accordion-header" id="headingMoneda">
            <button class="accordion-button bg-white text-dark fw-bold py-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapseMoneda" aria-expanded="true" aria-controls="collapseMoneda">
                <div class="d-flex align-items-center w-100">
                    <div class="bg-primary bg-opacity-10 p-2 rounded-2 me-3 text-primary">
                        <i class="fas fa-coins"></i>
                    </div>
                    <span>Administración de moneda y tasa</span>
                </div>
            </button>
        </h2>
        <div id="collapseMoneda" class="accordion-collapse collapse show" aria-labelledby="headingMoneda" data-bs-parent="#configAccordion">
            <div class="accordion-body bg-white pt-0">
                <div class="row">
                    <!-- Moneda Base -->
                    <div class="col-md-6 mb-4">
                        <div class="card border-0 bg-light h-100">
                            <div class="card-body">
                                <h6 class="fw-bold mb-3 text-secondary">MONEDA BASE</h6>
                                <form asp-action="CambiarMonedaBase" method="post">
                                    <div class="mb-3">
                                        <select name="idMonedaBase" class="form-select border-0 shadow-sm" onchange="showWarning()">
                                            @foreach (var m in monedas!)
                                            {
                                                <option value="@m.IdMoneda" selected="@(Model?.IdMonedaBase == m.IdMoneda)">
                                                    @m.Nombre (@m.Codigo - @m.Simbolo)
                                                </option>
                                            }
                                        </select>
                                    </div>
                                    <div id="baseWarning" class="alert alert-warning small py-2 d-none">
                                        <i class="fas fa-exclamation-triangle me-2"></i> Solo afecta nuevos registros.
                                    </div>
                                    <button type="submit" class="btn btn-primary btn-sm w-100">Actualizar Moneda</button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Tasa Actual -->
                    <div class="col-md-6 mb-4">
                        <div class="card border-0 bg-light h-100">
                            <div class="card-body">
                                <h6 class="fw-bold mb-3 text-secondary">TASA DE CAMBIO</h6>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h3 class="mb-0 fw-bold text-success">@(tasaActiva?.Valor.ToString("N6") ?? "N/A")</h3>
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill">Activa</span>
                                </div>
                                <form asp-action="GuardarTasa" method="post">
                                    <div class="input-group input-group-sm mb-2">
                                        <span class="input-group-text bg-white border-0 shadow-sm">1 USD = </span>
                                        <input type="number" step="0.000001" name="valor" class="form-control border-0 shadow-sm" required value="@tasaActiva?.Valor.ToString("F6").Replace(",",".")">
                                        <button class="btn btn-success" type="submit">Actualizar</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Historial -->
                    <div class="col-12">
                        <div class="card border-0 bg-light">
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover mb-0 align-middle">
                                        <thead class="bg-dark bg-opacity-10">
                                            <tr class="x-small fw-bold">
                                                <th class="ps-3 py-2">FECHA</th>
                                                <th class="py-2">VALOR (USD → NIO)</th>
                                                <th class="py-2 text-center">ESTADO</th>
                                                <th class="py-2 pe-3">USUARIO</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var t in historial!)
                                            {
                                                <tr class="small transition-all">
                                                    <td class="ps-3 py-2">@t.Fecha.ToString("g")</td>
                                                    <td><span class="fw-bold text-primary">@t.Valor.ToString("N6")</span></td>
                                                    <td class="text-center">
                                                        <span class="badge @(t.Activo ? "bg-success" : "bg-secondary opacity-50") rounded-pill" style="font-size: 0.65rem;">
                                                            @(t.Activo ? "ACTIVO" : "ANTERIOR")
                                                        </span>
                                                    </td>
                                                    <td class="pe-3 text-muted">@t.UsuarioModificacion</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SECCIÓN 2: ADMINISTRACIÓN DE USUARIOS -->
    <div class="accordion-item border-0 mb-3 rounded-3 overflow-hidden shadow-sm">
        <h2 class="accordion-header" id="headingUsuarios">
            <button class="accordion-button bg-white text-dark fw-bold py-3 collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseUsuarios" aria-expanded="false" aria-controls="collapseUsuarios">
                <div class="d-flex align-items-center w-100">
                    <div class="bg-info bg-opacity-10 p-2 rounded-2 me-3 text-info">
                        <i class="fas fa-users"></i>
                    </div>
                    <span>Administración de usuarios</span>
                </div>
            </button>
        </h2>
        <div id="collapseUsuarios" class="accordion-collapse collapse" aria-labelledby="headingUsuarios" data-bs-parent="#configAccordion">
            <div class="accordion-body bg-white pt-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle border-0">
                        <thead class="bg-light">
                            <tr class="text-secondary small fw-bold">
                                <th class="ps-3 border-0">USUARIO</th>
                                <th class="border-0">ROL</th>
                                <th class="border-0">ESTADO</th>
                                <th class="border-0">MÓDULOS ACTIVOS</th>
                                <th class="text-end pe-3 border-0">
                                    <button type="button" class="btn btn-primary btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#modalNuevoUsuario">
                                        <i class="fas fa-plus me-1"></i> Nuevo Usuario
                                    </button>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in usuarios!)
                            {
                                <tr class="transition-all @(u.IdEstado != 1 ? "border-start border-4 border-danger" : "border-start border-4 border-transparent")" style="background-color: @(u.IdEstado != 1 ? "#FFF5F5" : "transparent");">
                                    <td class="ps-3 py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm @(u.IdEstado == 1 ? "bg-primary text-primary" : "bg-danger text-danger") bg-opacity-10 rounded-circle me-3 d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 42px; height: 42px; font-size: 1.1rem;">
                                                @(u.Username.Substring(0,1).ToUpper())
                                            </div>
                                            <div>
                                                <div class="fw-bold mb-1 @(u.IdEstado != 1 ? "text-danger" : "text-dark")" style="font-size: 0.95rem;">
                                                    @u.Username
                                                    @if (u.IdEstado != 1)
                                                    {
                                                        <i class="fas fa-lock ms-2 small text-danger opacity-75" data-bs-toggle="tooltip" title="Acceso Revocado"></i>
                                                    }
                                                </div>
                                                <div class="x-small fw-medium @(u.IdEstado != 1 ? "text-danger opacity-75" : "text-muted")"><i class="fas fa-id-card me-1 opacity-50"></i>@(u.Empleado?.Persona?.PrimerNombre ?? "N/A")</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <span class="badge @(u.IdEstado == 1 ? "bg-soft-primary text-primary" : "bg-danger bg-opacity-10 text-danger") px-3 py-2 rounded-pill fw-bold border" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                                            @u.Role?.DescRol
                                        </span>
                                    </td>
                                    <td class="py-3">
                                        @if (u.IdEstado == 1)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill border border-success border-opacity-50 fw-bold d-inline-flex align-items-center gap-2 shadow-sm" style="font-size: 0.75rem;">
                                                <div class="rounded-circle bg-success shadow-sm" style="width: 8px; height: 8px;"></div> Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger text-white px-3 py-2 rounded-pill fw-bold d-inline-flex align-items-center gap-2 shadow-sm" style="font-size: 0.75rem;">
                                                <i class="fas fa-user-slash"></i> Suspendido
                                            </span>
                                        }
                                    </td>
                                    <td class="py-3" style="max-width: 250px;">
                                        <div class="d-flex flex-wrap gap-2">
                                            @if (u.UsuarioModulos != null && u.UsuarioModulos.Any())
                                            {
                                                foreach (var um in u.UsuarioModulos.OrderBy(x => x.Modulo?.Orden))
                                                {
                                                    <span class="badge bg-white text-dark border border-secondary border-opacity-25 fw-medium shadow-sm py-2 px-2" style="font-size: 0.7rem;">
                                                        <i class="@um.Modulo?.Icono text-primary opacity-75 me-1"></i> @um.Modulo?.Nombre
                                                    </span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-muted border border-secondary border-opacity-25 fw-normal py-2 px-2" style="font-size: 0.7rem;">Sin accesos</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="text-end pe-4 py-3">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button type="button" class="btn btn-light btn-sm rounded-circle shadow-sm border border-secondary border-opacity-10 d-flex align-items-center justify-content-center transition-all hover-primary" data-bs-toggle="modal" data-bs-target="#modalPermisos-@u.IdUsuario" style="width: 38px; height: 38px;" title="Gestionar Permisos" @(u.IdEstado != 1 ? "disabled" : "")>
                                                <i class="fas fa-shield-alt text-info fs-6"></i>
                                            </button>
                                            <button type="button" class="btn btn-light btn-sm rounded-circle shadow-sm border border-secondary border-opacity-10 d-flex align-items-center justify-content-center transition-all hover-primary" onclick="abrirModalEditar(@u.IdUsuario, '@u.Username')" style="width: 38px; height: 38px;" title="Editar Usuario" @(u.IdEstado != 1 ? "disabled" : "")>
                                                <i class="fas fa-pen text-primary fs-6"></i>
                                            </button>
                                            <button type="button" class="btn btn-light btn-sm rounded-circle shadow-sm border border-secondary border-opacity-10 d-flex align-items-center justify-content-center transition-all hover-danger" onclick="eliminarUsuario(@u.IdUsuario, '@u.Username', '@u.Role?.DescRol?.ToUpper()')" style="width: 38px; height: 38px;" title="@(u.Role?.DescRol?.ToUpper() == "DOCTOR" ? "Suspender Doctor" : "Eliminar permanentemente")" @(u.IdEstado != 1 ? "disabled" : "")>
                                                <i class="fas @(u.IdEstado != 1 ? "fa-ban text-muted" : "fa-trash-alt text-danger") fs-6"></i>
                                            </button>
                                        </div>

                                        <!-- MODAL DE PERMISOS -->
                                        <div class="modal fade" id="modalPermisos-@u.IdUsuario" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content border-0 shadow-lg shadow-sm">
                                                    <div class="modal-header border-0 bg-light">
                                                        <h5 class="modal-title fw-bold">Permisos de Módulos</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <form asp-action="GuardarPermisosUsuario" method="post">
                                                        <div class="modal-body text-start">
                                                            <input type="hidden" name="idUsuario" value="@u.IdUsuario" />
                                                            <p class="mb-3 text-muted small">Seleccione los módulos a los que el usuario <strong>@u.Username</strong> tendrá acceso:</p>
                                                            
                                                            <div class="row g-2">
                                                                @foreach (var mod in todosModulos!)
                                                                {
                                                                    var check = u.UsuarioModulos?.Any(um => um.IdModulo == mod.IdModulo) ?? false;
                                                                    <div class="col-6">
                                                                        <div class="form-check p-2 border rounded-3 bg-light transition-all hover-shadow-sm d-flex align-items-center">
                                                                            <input class="form-check-input ms-3 me-3" type="checkbox" name="modulosSeleccionados" value="@mod.IdModulo" id="mod-@u.IdUsuario-@mod.IdModulo" @(check ? "checked" : "")>
                                                                            <label class="form-check-label d-flex align-items-center gap-2 mb-0 cursor-pointer w-100" for="mod-@u.IdUsuario-@mod.IdModulo">
                                                                                <i class="@mod.Icono text-primary opacity-75"></i>
                                                                                <span class="small fw-medium">@mod.Nombre</span>
                                                                            </label>
                                                                        </div>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer border-0 pt-0">
                                                            <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cancelar</button>
                                                            <button type="submit" class="btn btn-info btn-sm text-white px-4">Guardar Cambios</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MODAL NUEVO USUARIO -->
<div class="modal fade" id="modalNuevoUsuario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 bg-light">
                <h5 class="modal-title fw-bold text-primary">Registrar Nuevo Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="formNuevoUsuario">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label small fw-bold">Nombre</label>
                            <input type="text" name="nombre" class="form-control form-control-sm" required placeholder="Ej: Juan" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-bold">Apellido</label>
                            <input type="text" name="apellido" class="form-control form-control-sm" required placeholder="Ej: Perez" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">Rol en el Sistema</label>
                            <select name="idRol" class="form-select form-select-sm" required>
                                @if (roles != null) {
                                    foreach (var r in roles) {
                                        <option value="@r.IdRol">@r.DescRol</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6 text-start">
                            <label class="form-label small fw-bold">N° Identificación</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-id-card text-muted"></i></span>
                                <input type="text" name="numIdentificacion" class="form-control border-start-0" required placeholder="000-000000-0000" />
                            </div>
                        </div>
                        <div class="col-md-6 text-start">
                            <label class="form-label small fw-bold">Teléfono (8 dígitos)</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-phone text-muted"></i></span>
                                <input type="text" name="telefono" class="form-control border-start-0" required placeholder="88888888" maxlength="8" pattern="\d{8}" />
                            </div>
                        </div>
                        <div class="col-12 text-start">
                            <label class="form-label small fw-bold">Fecha de Nacimiento</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-calendar-alt text-muted"></i></span>
                                <input type="date" name="fechaNacimiento" class="form-control border-start-0" required />
                            </div>
                        </div>
                        <div class="col-12 mt-3 p-3 bg-light rounded-3 border border-dashed text-center">
                            <i class="fas fa-user-shield text-muted mb-2"></i>
                            <div class="small fw-bold text-secondary">Credenciales de Acceso</div>
                        </div>
                        <div class="col-md-6 text-start">
                            <label class="form-label small fw-bold">Nombre de Usuario</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-at text-muted"></i></span>
                                <input type="text" name="username" class="form-control border-start-0" required placeholder="Ej: jperez" />
                            </div>
                        </div>
                        <div class="col-md-6 text-start">
                            <label class="form-label small fw-bold">Contraseña Inicial</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-lock text-muted"></i></span>
                                <input type="password" name="password" class="form-control border-start-0" required placeholder="********" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-primary btn-sm px-4" id="btnCrearUsuario">
                        Crear Usuario
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL EDITAR USUARIO -->
<div class="modal fade" id="modalEditarUsuario" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 bg-light">
                <h5 class="modal-title fw-bold text-primary">Editar Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="formEditarUsuario">
                @Html.AntiForgeryToken()
                <input type="hidden" name="idUsuario" id="editUserId" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12 text-start">
                            <label class="form-label small fw-bold">Nombre de Usuario</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-at text-muted"></i></span>
                                <input type="text" name="username" id="editUsername" class="form-control border-start-0" required placeholder="Ej: jperez" />
                            </div>
                        </div>
                        <div class="col-12 mt-3 p-3 bg-light rounded-3 border border-dashed text-center">
                            <i class="fas fa-key text-muted mb-2"></i>
                            <div class="small fw-bold text-secondary">Seguridad y Acceso</div>
                        </div>
                        <div class="col-12 text-start">
                            <label class="form-label small fw-bold">Nueva Contraseña (Opcional)</label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border-end-0"><i class="fas fa-lock text-muted"></i></span>
                                <input type="password" name="password" class="form-control border-start-0" placeholder="Dejar en blanco para mantener actual" />
                            </div>
                            <div class="small text-muted mt-1"><i class="fas fa-info-circle me-1"></i> Solo complete este campo si desea restablecer la contraseña.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-primary btn-sm px-4" id="btnActualizarUsuario">
                        Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .x-small { font-size: 0.75rem; }
    .bg-light { background-color: #F8FAFC !important; }
    .bg-soft-primary { background-color: #EFF6FF !important; }
    .btn-outline-danger { color: #EF4444; border-color: #FCA5A5; }
    .btn-outline-danger:hover { background-color: #EF4444; color: white; border-color: #EF4444; }
    
    .accordion-button:not(.collapsed) {
        background-color: white !important;
        box-shadow: none !important;
        color: var(--primary-blue) !important;
    }
    
    .accordion-button:focus {
        box-shadow: none !important;
        border-color: rgba(0,0,0,.125);
    }

    .accordion-button::after {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%2364748B'%3e%3cpath fill-rule='evenodd' d='M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z'/%3e%3c/svg%3e") !important;
        background-size: 1.25rem !important;
        transition: transform 0.2s ease-in-out !important;
    }

    .transition-all { transition: all 0.2s ease; }
    .hover-shadow-sm:hover { box-shadow: 0 .125rem .25rem rgba(0,0,0,.075) !important; background-color: #f1f5f9 !important; }
    .cursor-pointer { cursor: pointer; }
    
    .form-check-input:checked {
        background-color: var(--primary-blue);
        border-color: var(--primary-blue);
    }
    
    .border-transparent { border-color: transparent !important; }
    
    .btn.hover-primary:hover:not(:disabled) { background-color: #EFF6FF; border-color: #BFDBFE !important; }
    .btn.hover-primary:hover:not(:disabled) i { color: #2563EB !important; }
    
    .btn.hover-danger:hover:not(:disabled) { background-color: #FEF2F2; border-color: #FECACA !important; }
    .btn.hover-danger:hover:not(:disabled) i { color: #DC2626 !important; }
    
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
</style>

@section Scripts {
    <script>
        function showWarning() {
            $('#baseWarning').removeClass('d-none');
        }

        // REGISTRO DE USUARIO AJAX
        $('#formNuevoUsuario').on('submit', function(e) {
            e.preventDefault();
            const $btn = $('#btnCrearUsuario');
            const originalText = $btn.html();
            
            $btn.html('<i class="fas fa-spinner fa-spin me-2"></i>Creando...').prop('disabled', true);

            $.ajax({
                url: '@Url.Action("RegistrarUsuario")',
                type: 'POST',
                data: $(this).serialize(),
                success: function(resp) {
                    if (resp.success) {
                        MediToast.success(resp.message);
                        const modal = bootstrap.Modal.getInstance(document.getElementById('modalNuevoUsuario'));
                        if (modal) modal.hide();
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        MediToast.error(resp.message);
                        $btn.html(originalText).prop('disabled', false);
                    }
                },
                error: function(xhr) {
                    MediToast.error("Error al procesar la solicitud (Status: " + xhr.status + ")");
                    $btn.html(originalText).prop('disabled', false);
                }
            });
        });

        function abrirModalEditar(id, username) {
            $('#editUserId').val(id);
            $('#editUsername').val(username);
            $('#modalEditarUsuario').modal('show');
        }

        $('#formEditarUsuario').on('submit', function(e) {
            e.preventDefault();
            const $btn = $('#btnActualizarUsuario');
            const originalText = $btn.html();
            
            $btn.html('<i class="fas fa-spinner fa-spin me-2"></i>Guardando...').prop('disabled', true);

            $.ajax({
                url: '@Url.Action("ActualizarUsuario")',
                type: 'POST',
                data: $(this).serialize(),
                success: function(resp) {
                    if (resp.success) {
                        MediToast.success(resp.message);
                        const modal = bootstrap.Modal.getInstance(document.getElementById('modalEditarUsuario'));
                        if (modal) modal.hide();
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        MediToast.error(resp.message);
                        $btn.html(originalText).prop('disabled', false);
                    }
                },
                error: function(xhr) {
                    MediToast.error("Error al procesar la solicitud (Status: " + xhr.status + ")");
                    $btn.html(originalText).prop('disabled', false);
                }
            });
        });

        // Auto-hide alerts
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);

        function eliminarUsuario(id, username, rol) {
            const isDoctor = (rol === 'DOCTOR');
            const actionText = isDoctor ? 'suspender' : 'eliminar permanentemente';
            const actionColor = isDoctor ? 'warning' : 'danger';
            const title = isDoctor ? '¿Suspender Doctor?' : '¿Eliminar Usuario?';
            const message = isDoctor 
                ? `El Doctor <strong>${username}</strong> dejará de tener acceso al sistema, pero sus registros médicos históricos se mantendrán protegidos.` 
                : `¿Está seguro de eliminar a <strong>${username}</strong>? Esta acción no se puede deshacer.`;

            MediConfirm.show({
                title: title,
                message: message,
                variant: actionColor,
                confirmText: isDoctor ? 'Sí, Suspender' : 'Sí, Eliminar',
                cancelText: 'Cancelar',
                icon: isDoctor ? 'fa-user-slash' : 'fa-user-times'
            }).then(confirmed => {
                if (confirmed) {
                    const token = $('input[name="__RequestVerificationToken"]').val();
                    $.ajax({
                        url: '@Url.Action("EliminarUsuario")',
                        type: 'POST',
                        dataType: 'json',
                        data: { 
                            id: id,
                            __RequestVerificationToken: token
                        },
                        success: function(resp) {
                            if (resp.success) {
                                MediToast.success(resp.message);
                                setTimeout(() => location.reload(), 1500);
                            } else {
                                MediToast.error(resp.message);
                            }
                        },
                        error: function(xhr) {
                            console.error("Error Delete User:", xhr);
                            MediToast.error("Error de comunicación con el servidor (Status: " + xhr.status + ").");
                        }
                    });
                }
            });
        }
    </script>
}

