@model IEnumerable<MediTech.Backend.Models.Paciente>
@{
    ViewData["Title"] = "Pacientes";
}

<style>

    .search-bar {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
    }
    .search-bar input {
        flex: 1;
        border: 1px solid #E2E8F0;
        border-radius: 8px;
        padding: 10px 16px;
        font-size: 0.88rem;
        outline: none;
        transition: border-color 0.15s;
    }
    .search-bar input:focus { border-color: #3B82F6; }

    .patients-table {
        background: #FFFFFF;
        border-radius: 14px;
        border: 1px solid #E2E8F0;
        overflow-x: auto;
    }
    .patients-table table {
        width: 100%;
        border-collapse: collapse;
    }
    .patients-table th {
        background: #F8FAFC;
        padding: 12px 16px;
        font-size: 0.78rem;
        font-weight: 600;
        color: #64748B;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        text-align: left;
        border-bottom: 1px solid #E2E8F0;
    }
    .patients-table td {
        padding: 14px 16px;
        font-size: 0.88rem;
        color: #334155;
        border-bottom: 1px solid #F1F5F9;
    }
    .patients-table tr:hover td { background: #F8FAFC; }
    .patients-table tr:last-child td { border-bottom: none; }

    .patient-name-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .patient-avatar {
        width: 36px; height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 0.75rem;
        color: #FFFFFF;
    }

    .badge-active {
        background: #D1FAE5; color: #065F46;
        font-size: 0.72rem; padding: 3px 10px;
        border-radius: 20px; font-weight: 600;
    }
    .badge-inactive {
        background: #FEE2E2; color: #991B1B;
        font-size: 0.72rem; padding: 3px 10px;
        border-radius: 20px; font-weight: 600;
    }

    .action-link {
        color: #3B82F6;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.82rem;
        margin-right: 12px;
    }
    .action-link:hover { text-decoration: underline; }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #94A3B8;
    }
    .empty-state i { font-size: 3rem; margin-bottom: 12px; color: #CBD5E1; }

    .toast-success {
        position: fixed; top: 80px; right: 28px;
        background: #065F46; color: white;
        padding: 12px 20px; border-radius: 8px;
        font-size: 0.85rem; font-weight: 500;
        z-index: 9999; animation: fadeIn 0.3s;
    }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
    .pagination-container {
        padding: 16px;
        display: flex;
        justify-content: center;
        background: #F8FAFC;
        border-top: 1px solid #E2E8F0;
    }
    .pagination {
        display: flex;
        gap: 6px;
        list-style: none;
        margin: 0;
        padding: 0;
    }
    .page-item.disabled .page-link {
        color: #CBD5E1;
        pointer-events: none;
    }
    .page-item.active .page-link {
        background: #3B82F6;
        color: #FFFFFF;
        border-color: #3B82F6;
    }
    .page-link {
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 34px;
        height: 34px;
        padding: 0 8px;
        font-size: 0.82rem;
        font-weight: 500;
        color: #64748B;
        text-decoration: none;
        background: #FFFFFF;
        border: 1px solid #E2E8F0;
        border-radius: 6px;
        transition: all 0.2s;
    }
    .page-link:hover {
        background: #F1F5F9;
        color: #3B82F6;
        border-color: #CBD5E1;
    }
</style>

@if (TempData["SuccessMessage"] != null)
{
    <div class="toast-success" id="toast">
        <i class="fas fa-check-circle me-1"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="page-header page-header-premium mb-3 d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h2 class="mb-0"><i class="fas fa-user-injured me-2" style="color:#3B82F6;"></i>Pacientes</h2>
        <span class="subtitle">Gestión de pacientes registrados <strong class="ms-2 d-none d-sm-inline">(@ViewBag.TotalItems total)</strong></span>
    </div>
    <button type="button" class="btn btn-primary px-4 py-2" data-bs-toggle="modal" data-bs-target="#createPacienteModal" style="border-radius:12px; font-weight:600; width: auto !important;">
        <i class="fas fa-plus me-1"></i> Nuevo Paciente
    </button>
</div>

<form method="get" class="mb-4 mt-3">
    <div class="input-group" style="box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control border-end-0" 
               placeholder="Buscar nombre o identificación..." 
               style="border-radius: 12px 0 0 12px; padding: 12px 20px; font-size: 0.9rem;">
        <button type="submit" class="btn btn-white border-start-0 border-end-0 bg-white text-primary" 
                style="border-color: #E2E8F0; padding: 0 15px;">
            <i class="fas fa-search"></i>
        </button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a href="@Url.Action("Index")" class="btn btn-white border-start-0 bg-white text-muted d-flex align-items-center" style="border-radius: 0 12px 12px 0; border-left: 1px solid #eee;">
                <i class="fas fa-times"></i>
            </a>
        }
        else
        {
             <div class="input-group-text bg-white border-start-0" style="border-radius: 0 12px 12px 0; border-color: #E2E8F0;"></div>
        }
    </div>
</form>

<div class="patients-table table-responsive-premium">
    @if (Model.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>Paciente</th>
                    <th>Identificación</th>
                    <th>Teléfono</th>
                    <th>Sexo</th>
                    <th>Fecha Registro</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @{ var colors = new[] { "#3B82F6", "#10B981", "#8B5CF6", "#F59E0B", "#EF4444", "#06B6D4" }; }
                @foreach (var (p, i) in Model.Select((p, i) => (p, i)))
                {
                    var initials = ((p.Persona?.PrimerNombre?.Length > 0 ? p.Persona.PrimerNombre[0].ToString() : "") +
                                   (p.Persona?.PrimerApellido?.Length > 0 ? p.Persona.PrimerApellido[0].ToString() : "")).ToUpper();
                    var color = colors[i % colors.Length];
                    <tr>
                        <td data-label="Paciente">
                            <div class="patient-name-cell">
                                <div class="patient-avatar" style="background:@color;">@initials</div>
                                <div>
                                    <strong>@p.Persona?.PrimerNombre @p.Persona?.PrimerApellido</strong>
                                    @if (!string.IsNullOrEmpty(p.Persona?.SegundoApellido))
                                    {
                                        <span style="color:#94A3B8;"> @p.Persona.SegundoApellido</span>
                                    }
                                </div>
                            </div>
                        </td>
                        <td data-label="Identificación">@(p.Persona?.NumIdentificacion ?? "—")</td>
                        <td data-label="Teléfono">@(p.Persona?.Telefono ?? "—")</td>
                        <td data-label="Sexo">@(p.Persona?.IdGenero == 1 ? "Masculino" : p.Persona?.IdGenero == 2 ? "Femenino" : "—")</td>
                        <td data-label="Fecha Registro">@(p.FechaRegistro?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td data-label="Estado">
                            <span class="@(p.IdEstado == 1 ? "badge-active" : "badge-inactive")">
                                @(p.IdEstado == 1 ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td data-label="Acciones">
                            <a href="@Url.Action("Details", new { id = p.IdPaciente })" class="action-link" title="Detalles"><i class="fas fa-eye"></i></a>
                            <a href="@Url.Action("Ficha", new { id = p.IdPaciente })" class="action-link" title="Ver Ficha" style="color: #10B981;"><i class="fas fa-file-medical"></i></a>
                            <a href="@Url.Action("Edit", new { id = p.IdPaciente })" class="action-link" title="Editar" style="color: #F59E0B;"><i class="fas fa-pencil-alt"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="pagination-container">
                <ul class="pagination">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1, search = ViewBag.Search })">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link"><i class="fas fa-chevron-left"></i></span>
                        </li>
                    }

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { page = i, search = ViewBag.Search })">@i</a>
                        </li>
                    }

                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1, search = ViewBag.Search })">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link"><i class="fas fa-chevron-right"></i></span>
                        </li>
                    }
                </ul>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <div><i class="fas fa-user-slash"></i></div>
            <h5>No se encontraron pacientes</h5>
            <p>@(string.IsNullOrEmpty(ViewBag.Search as string) ? "Aún no hay pacientes registrados. Haz clic en \"Nuevo Paciente\" para comenzar." : "No hay resultados para tu búsqueda.")</p>
        </div>
    }
</div>



@section Modals {
    <!-- Modal: Registro de Nuevo Paciente (Premium) -->
    <div class="modal fade" id="createPacienteModal" tabindex="-1" aria-labelledby="createPacienteModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 24px;">
                <div class="modal-header bg-transparent border-0 pt-4 px-4 d-flex align-items-center">
                    <div class="icon-shape bg-soft-primary rounded-circle me-3 p-3">
                        <i class="fas fa-user-plus text-primary fs-4"></i>
                    </div>
                    <div>
                        <h4 class="modal-title fw-bold text-dark mb-0" id="createPacienteModalLabel">Nuevo Registro de Paciente</h4>
                        <p class="text-muted small mb-0">Complete los datos obligatorios (*) para el nuevo expediente</p>
                    </div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 pt-2">
                    <form id="createPacienteForm">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-12"><div class="section-title mb-2" style="color:#3B82F6; font-weight:700;"><i class="fas fa-id-card me-2"></i>DATOS PERSONALES</div></div>
                            <div class="col-sm-6 col-lg-3">
                                <label class="small fw-bold text-muted">Primer Nombre *</label>
                                <input name="Persona.PrimerNombre" class="form-control" required />
                            </div>
                            <div class="col-sm-6 col-lg-3">
                                <label class="small fw-bold text-muted">Segundo Nombre</label>
                                <input name="Persona.SegundoNombre" class="form-control" />
                            </div>
                            <div class="col-sm-6 col-lg-3">
                                <label class="small fw-bold text-muted">Primer Apellido *</label>
                                <input name="Persona.PrimerApellido" class="form-control" required />
                            </div>
                            <div class="col-sm-6 col-lg-3">
                                <label class="small fw-bold text-muted">Segundo Apellido</label>
                                <input name="Persona.SegundoApellido" class="form-control" />
                            </div>

                            <div class="col-sm-6 col-lg-3">
                                <label class="small fw-bold text-muted">Género</label>
                                <select name="Persona.IdGenero" class="form-select" required>
                                    <option value="">Seleccione</option>
                                    @if (ViewBag.Generos != null) {
                                        @foreach (var g in (IEnumerable<MediTech.Backend.Models.Genero>)ViewBag.Generos) { <option value="@g.IdGenero">@g.DescGenero</option> }
                                    }
                                </select>
                            </div>
                            <div class="col-sm-6 col-lg-3">
                                <label class="small fw-bold text-muted">Tipo Identificación</label>
                                <select name="Persona.IdTipoIdentificacion" class="form-select">
                                    <option value="">Seleccione</option>
                                    @if (ViewBag.TiposIdentificacion != null) {
                                        @foreach (var t in (IEnumerable<MediTech.Backend.Models.TipoIdentificacion>)ViewBag.TiposIdentificacion) { <option value="@t.IdTipoIdentificacion">@t.DescTipo</option> }
                                    }
                                </select>
                            </div>
                            <div class="col-sm-6 col-lg-3">
                                <label class="small fw-bold text-muted">N° Identificación</label>
                                <input name="Persona.NumIdentificacion" class="form-control" />
                            </div>
                            <div class="col-sm-6 col-lg-3">
                                <label class="small fw-bold text-muted">Fecha de Nacimiento *</label>
                                <input name="Persona.FechaNacimiento" type="date" class="form-control" required />
                            </div>

                            <div class="col-sm-6 col-lg-4">
                                <label class="small fw-bold text-muted">Ocupación</label>
                                <input name="Ocupacion" class="form-control" />
                            </div>
                            <div class="col-sm-6 col-lg-4">
                                <label class="small fw-bold text-muted">Correo Electrónico</label>
                                <input name="Persona.Email" type="email" class="form-control" />
                            </div>
                            <div class="col-sm-12 col-lg-4">
                                <label class="small fw-bold text-muted">Teléfono *</label>
                                <input name="Persona.Telefono" class="form-control" required />
                            </div>
                            <div class="col-12">
                                <label class="small fw-bold text-muted">Dirección</label>
                                <textarea name="Persona.Direccion" class="form-control" rows="2"></textarea>
                            </div>

                            <div class="col-12 mt-4"><div class="section-title mb-2" style="color:#F59E0B; font-weight:700;"><i class="fas fa-phone-alt me-2"></i>CONTACTO DE EMERGENCIA</div></div>
                            <div class="col-md-6">
                                <label class="small fw-bold text-muted">Nombre del Contacto</label>
                                <input name="ContactoEmergencia" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="small fw-bold text-muted">Teléfono de Emergencia</label>
                                <input name="TelefonoEmergencia" class="form-control" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-5 pt-3 border-top">
                            <button type="button" class="btn btn-light-premium px-4" data-bs-dismiss="modal">Cancelar</button>
                            <button type="submit" class="btn btn-primary-premium px-5 shadow-sm">
                                <i class="fas fa-save me-2"></i>Guardar Paciente
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            // Toast timeout logic
            setTimeout(() => { var t = document.getElementById('toast'); if (t) t.style.display = 'none'; }, 4000);

            // Auto-open logic
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('autoOpen') === '1') {
                const modal = new bootstrap.Modal(document.getElementById('createPacienteModal'));
                modal.show();
                window.history.replaceState({}, document.title, window.location.pathname);
            }

            // AJAX Submit
            $('#createPacienteForm').on('submit', function(e) {
                e.preventDefault();
                const $form = $(this);
                const $btn = $form.find('button[type="submit"]');
                const originalText = $btn.html();

                $btn.html('<i class="fas fa-spinner fa-spin me-2"></i>Guardando...').prop('disabled', true);

                $.ajax({
                    url: '@Url.Action("Create")',
                    type: 'POST',
                    data: $form.serialize(),
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    success: function(response) {
                        location.reload();
                    },
                    error: function(xhr) {
                        alert("Error al registrar paciente. Verifique los datos o si ya existe.");
                        $btn.html(originalText).prop('disabled', false);
                    }
                });
            });
        });
    </script>
}
