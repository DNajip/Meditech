@model MediTech.Backend.Models.Cuenta

@{
    ViewData["Title"] = "Detalle de Cuenta #" + Model.IdCuenta;
    var monedas = ViewBag.Monedas as List<MediTech.Backend.Models.Moneda>;
    decimal totalPagado = ViewBag.TotalPagado;
    decimal saldoPendiente = ViewBag.SaldoPendiente;
    bool isCancelada = (Model.TotalFinal ?? 0) == 0;
    bool isPagada = !isCancelada && saldoPendiente <= 0 && (Model.TotalFinal ?? 0) > 0;
    var nombrePaciente = Model.Paciente?.Persona != null
        ? $"{Model.Paciente.Persona.PrimerNombre} {Model.Paciente.Persona.PrimerApellido}"
        : "N/A";
}

<div class="page-header page-header-premium mb-4">
    <div>
        <h2 class="display-6 fw-bold text-gradient-primary mb-0">Detalle de Cuenta #@Model.IdCuenta</h2>
        <p class="text-muted d-none d-sm-block">Gestión de cobros, pagos y estados de cuenta</p>
    </div>
    <div class="d-flex flex-wrap gap-2 justify-content-start justify-content-sm-end">
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm px-3" id="btnVolver" style="border-radius:12px;">
            <i class="fas fa-arrow-left me-1"></i> <span class="d-none d-sm-inline">Volver</span>
        </a>
        @if (!isCancelada && !isPagada)
        {
            <button type="button" class="btn btn-success shadow-sm px-4" data-bs-toggle="modal" data-bs-target="#registrarPagoModal" id="btnRegistrarPago" style="border-radius:12px;">
                <i class="fas fa-dollar-sign me-1"></i> <span class="d-none d-sm-inline">Registrar Pago</span><span class="d-sm-none">Pagar</span>
            </button>
        }
        @if (!isCancelada && !isPagada && totalPagado == 0 && (Model.TotalFinal ?? 0) > 0)
        {
            <button type="button" class="btn btn-outline-danger shadow-sm px-3" id="btnAnularCuenta" style="border-radius:12px;">
                <i class="fas fa-ban"></i>
            </button>
        }
    </div>
</div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Info Card -->
        <div class="col-lg-4 col-sm-12">
            <div class="card card-premium border-0 shadow-sm h-100">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="avatar-lg bg-soft-primary rounded-circle mx-auto d-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px;">
                            <i class="fas fa-file-invoice-dollar text-primary fs-3"></i>
                        </div>
                        <span class="badge @(isCancelada ? "bg-soft-secondary text-secondary" : (isPagada ? "bg-success" : "bg-warning text-dark")) rounded-pill fs-6 px-3 py-2">
                            @(isCancelada ? "✕ CANCELADA" : (isPagada ? "✓ PAGADA" : "⏳ PENDIENTE"))
                        </span>
                    </div>

                    <ul class="list-unstyled">
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted">Paciente</span>
                            <span class="fw-bold">@nombrePaciente</span>
                        </li>
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted">Moneda</span>
                            <span class="fw-bold">@Model.MonedaBase?.Nombre (@Model.MonedaBase?.Codigo)</span>
                        </li>
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted">Fecha</span>
                            <span class="fw-bold">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</span>
                        </li>
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span class="text-muted">Tasa de Cambio</span>
                            <span class="fw-bold">@ViewBag.TasaCambio</span>
                        </li>
                    </ul>

                    <div class="bg-light rounded-3 p-3 mt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal:</span>
                            <span class="fw-bold">@Model.MonedaBase?.Simbolo @Model.TotalBruto?.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Descuento:</span>
                            <span class="fw-bold text-danger">- @Model.MonedaBase?.Simbolo @Model.Descuento.ToString("N2")</span>
                        </div>
                        <hr class="my-2">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="fw-bold fs-5">Total:</span>
                            <span class="fw-bold fs-5 text-primary">@Model.MonedaBase?.Simbolo @Model.TotalFinal?.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Pagado:</span>
                            <span class="fw-bold text-success">@Model.MonedaBase?.Simbolo @totalPagado.ToString("N2")</span>
                        </div>
                        <hr class="my-2">
                        <div class="d-flex justify-content-between">
                            <span class="fw-bold fs-5">Saldo:</span>
                            <span class="fw-bold fs-5 @(saldoPendiente > 0 ? "text-danger" : "text-success")">@Model.MonedaBase?.Simbolo @saldoPendiente.ToString("N2")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Items & Payments -->
        <div class="col-lg-8 col-sm-12">
            <!-- Items de la Cuenta -->
            <div class="card card-premium border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0"><i class="fas fa-list text-primary me-2"></i>Ítems de la Cuenta</h5>
                </div>
                <div class="card-body px-0 px-md-4">
                    <div class="table-responsive-premium">
                        <table class="table align-middle mb-0">
                            <thead class="bg-light-faded">
                                <tr>
                                    <th>Tipo</th>
                                    <th>Descripción</th>
                                    <th class="text-center">Cant.</th>
                                    <th class="text-end">Precio Unit.</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Detalles)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge @(item.TipoItem == "TRATAMIENTO" ? "bg-soft-success text-success" : "bg-soft-info text-info") rounded-pill">
                                                @item.TipoItem
                                            </span>
                                        </td>
                                        <td class="fw-semibold">@item.Descripcion</td>
                                        <td class="text-center">@item.Cantidad</td>
                                        <td class="text-end">@Model.MonedaBase?.Simbolo @item.PrecioUnitario?.ToString("N2")</td>
                                        <td class="text-end fw-bold">@Model.MonedaBase?.Simbolo @item.Subtotal?.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Historial de Pagos -->
            <div class="card card-premium border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="fas fa-money-bill-wave text-success me-2"></i>Historial de Pagos</h5>
                    <span class="badge bg-primary rounded-pill">@Model.Pagos.Count pagos</span>
                </div>
                <div class="card-body px-0 px-md-4">
                    @if (!Model.Pagos.Any())
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="fas fa-receipt fa-3x mb-3 d-block opacity-25"></i>
                            Aún no se han registrado pagos para esta cuenta.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive-premium">
                            <table class="table align-middle mb-0">
                                <thead class="bg-light-faded">
                                    <tr>
                                        <th># Pago</th>
                                        <th>Método</th>
                                        <th class="text-end">Monto Neto</th>
                                        <th class="text-end text-primary small">Recibido</th>
                                        <th class="text-end text-success small">Vuelto</th>
                                        <th>Moneda</th>
                                        <th>Fecha</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pago in Model.Pagos.OrderByDescending(p => p.FechaPago))
                                    {
                                        <tr>
                                            <td><span class="badge bg-light text-dark">#@pago.IdPago</span></td>
                                            <td>
                                                <span class="badge @GetMetodoClass(pago.MetodoPago) rounded-pill">
                                                    <i class="@GetMetodoIcon(pago.MetodoPago) me-1"></i>@pago.MetodoPago
                                                </span>
                                            </td>
                                            <td class="text-end fw-bold text-success">@pago.Moneda?.Simbolo @pago.Monto?.ToString("N2")</td>
                                            <td class="text-end text-primary small">@(pago.MontoRecibido > 0 ? pago.Moneda?.Simbolo + " " + pago.MontoRecibido?.ToString("N2") : "-")</td>
                                            <td class="text-end text-success small">@(pago.Vuelto > 0 ? Model.MonedaBase?.Simbolo + " " + pago.Vuelto?.ToString("N2") : "-")</td>
                                            <td>@pago.Moneda?.Nombre</td>
                                            <td class="text-muted small">@pago.FechaPago.ToString("dd/MM/yyyy HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div id="currency-metadata" 
     data-base-id="@ViewBag.IdMonedaBase" 
     data-base-codigo="@ViewBag.MonedaBase?.Codigo"
     data-tasa="@ViewBag.TasaCambio"
     data-saldo="@ViewBag.SaldoPendiente"
     data-cuenta-codigo="@Model.MonedaBase?.Codigo"
     data-tasa-origen="@ViewBag.TasaOrigenId"
     data-tasa-destino="@ViewBag.TasaDestinoId"
     style="display:none;"></div>

<!-- Modal Registrar Pago -->
<div class="modal fade" id="registrarPagoModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 1.2rem;">
            <div class="modal-header bg-success bg-opacity-10 border-0 pt-4 px-4">
                <h5 class="modal-title fw-bold text-success">
                    <i class="fas fa-dollar-sign me-2"></i>Registrar Pago
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="formRegistrarPago" asp-action="RegistrarPago" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" name="idCuenta" value="@Model.IdCuenta" />
                    <input type="hidden" name="idMoneda" id="hiddenIdMoneda" value="@Model.IdMonedaBase" />
                    <input type="hidden" name="monto" id="hiddenMontoPagar" value="@saldoPendiente" />

                    <!-- Header Saldo -->
                    <div class="bg-soft-danger rounded-4 p-3 mb-4 text-center border border-danger border-opacity-10">
                        <span class="text-danger-emphasis small fw-bold text-uppercase d-block mb-1">Saldo Pendiente</span>
                        <h2 class="fw-bold text-danger mb-0 font-monospace">@Model.MonedaBase?.Simbolo @saldoPendiente.ToString("N2")</h2>
                    </div>

                    <div id="multiCurrencyContainer">
                        <!-- Entrada NIO -->
                        <div class="p-3 mb-3" style="background: #f8fafc; border-radius: 12px; border: 1px solid #e2e8f0;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="fw-bold small text-secondary"><i class="fas fa-money-bill-alt me-1 text-primary"></i> Pagar en Córdoba (NIO)</label>
                                <div class="d-flex gap-1">
                                    <span class="badge bg-soft-primary text-primary" id="badgeBaseNIO" style="font-size: 0.65rem; display:none;">MONEDA BASE</span>
                                    <span class="badge bg-soft-warning text-warning" id="badgeCuentaNIO" style="font-size: 0.65rem; display:none;">MONEDA CUENTA</span>
                                </div>
                            </div>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-0 shadow-sm" style="border-radius: 8px 0 0 8px;">C$</span>
                                <input type="number" id="inputMontoNIO" class="form-control border-0 shadow-sm fw-bold" step="0.01" placeholder="0.00" style="border-radius: 0 8px 8px 0;">
                            </div>
                            <div class="mt-2 text-end">
                                <span class="text-muted" style="font-size: 0.75rem;">Vale: <span id="nioEquivLabel" class="fw-bold text-primary">--</span></span>
                            </div>
                        </div>

                        <!-- Entrada USD -->
                        <div class="p-3 mb-4" style="background: #f0fdf4; border-radius: 12px; border: 1px solid #dcfce7;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="fw-bold small text-success"><i class="fas fa-dollar-sign me-1"></i> Pagar en Dólares (USD)</label>
                                <div class="d-flex gap-1">
                                    <span class="badge bg-soft-success text-success" id="conversionFactorLabel" style="font-size: 0.65rem;">Tasa: --.--</span>
                                    <span class="badge bg-soft-primary text-primary" id="badgeBaseUSD" style="font-size: 0.65rem; display:none;">MONEDA BASE</span>
                                    <span class="badge bg-soft-warning text-warning" id="badgeCuentaUSD" style="font-size: 0.65rem; display:none;">MONEDA CUENTA</span>
                                </div>
                            </div>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-0 shadow-sm" style="border-radius: 8px 0 0 8px;">$</span>
                                <input type="number" id="inputMontoUSD" class="form-control border-0 shadow-sm fw-bold" step="0.01" placeholder="0.00" style="border-radius: 0 8px 8px 0;">
                            </div>
                            <div class="mt-2 text-end">
                                <span class="text-muted" style="font-size: 0.75rem;">Vale: <span id="usdEquivLabel" class="fw-bold text-success">C$ 0.00</span></span>
                            </div>
                        </div>
                    </div>

                    <div class="row g-2 mb-4">
                        <div class="col-8">
                            <label class="form-label fw-bold small text-secondary">Vía de Pago <span class="text-danger">*</span></label>
                            <select name="metodoPago" id="selectMetodoPago" class="form-select border-0 bg-light fw-semibold" style="border-radius: 8px;" required>
                                <option value="EFECTIVO">💵 Efectivo</option>
                                <option value="TARJETA">💳 Tarjeta</option>
                                <option value="TRANSFERENCIA">🏦 Transferencia</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <label class="form-label fw-bold small text-secondary">Total Cubierto</label>
                            <div class="text-end fw-bold text-primary py-1" id="totalCubiertoLabel" style="font-size: 1.1rem;">C$ 0.00</div>
                        </div>
                    </div>

                    <!-- Sección Resumen y Cambio -->
                    <div id="sectionResumen" class="mt-2 text-start">
                        <div id="alertRestante" class="p-2 mb-3 bg-soft-info rounded-3 text-center border border-info border-opacity-10">
                            <span class="text-info-emphasis fw-semibold" style="font-size: 0.8rem;">Restante: <span id="restanteValor">C$ @saldoPendiente.ToString("N2")</span></span>
                        </div>

                        <div id="displayVuelto" class="p-3 bg-soft-success rounded-4 border border-success border-opacity-10 text-center" style="display:none;">
                            <span class="text-success-emphasis small fw-bold text-uppercase d-block mb-1">Vuelto Estimado (NIO)</span>
                            <h3 class="fw-bold text-success mb-0 font-monospace">C$ <span id="vueltoValor">0.00</span></h3>
                        </div>
                    </div>

                    <div id="pagoInsuficiente" class="alert alert-danger mt-3 py-2 px-3 small border-0 shadow-sm" style="display:none;">
                        <i class="fas fa-exclamation-circle me-1"></i> El monto total no cubre el saldo de la cuenta.
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold text-muted" data-bs-dismiss="modal">Cerrar</button>
                    <button type="submit" class="btn btn-success rounded-pill px-5 fw-bold shadow-sm" id="btnSubmitPago">
                        <i class="fas fa-check-circle me-2"></i>Confirmar Cobro
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    string GetMetodoClass(string? metodo) => metodo switch
    {
        "EFECTIVO" => "bg-soft-success text-success",
        "TARJETA" => "bg-soft-primary text-primary",
        "TRANSFERENCIA" => "bg-soft-info text-info",
        _ => "bg-light text-dark"
    };

    string GetMetodoIcon(string? metodo) => metodo switch
    {
        "EFECTIVO" => "fas fa-money-bill-wave",
        "TARJETA" => "fas fa-credit-card",
        "TRANSFERENCIA" => "fas fa-university",
        _ => "fas fa-question"
    };
}


@Html.AntiForgeryToken()

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // UI Elements
        const formPago = document.getElementById('formRegistrarPago');
        const inputNIO = document.getElementById('inputMontoNIO');
        const inputUSD = document.getElementById('inputMontoUSD');
        const factorLabel = document.getElementById('conversionFactorLabel');
        const nioEquivLabel = document.getElementById('nioEquivLabel'); // Nueva etiqueta
        const usdEquivLabel = document.getElementById('usdEquivLabel');
        const totalCubiertoLabel = document.getElementById('totalCubiertoLabel');
        const restanteValor = document.getElementById('restanteValor');
        const alertRestante = document.getElementById('alertRestante');
        
        const selectMetodo = document.getElementById('selectMetodoPago');
        const displayVuelto = document.getElementById('displayVuelto');
        const vueltoValor = document.getElementById('vueltoValor');
        const alertInsuficiente = document.getElementById('pagoInsuficiente');
        const btnSubmit = document.getElementById('btnSubmitPago');
        
        // Metadata
        const meta = document.getElementById('currency-metadata');
        if (!meta) return;

        const saldoPendienteOriginal = parseFloat(meta.dataset.saldo.replace(',', '.')) || 0;
        const tasa = parseFloat(meta.dataset.tasa.replace(',', '.')) || 1;
        const codigoBase = meta.dataset.baseCodigo;
        const codigoCuenta = meta.dataset.cuentaCodigo;
        
        const idNIO = @monedas.FirstOrDefault(m => m.Codigo == "NIO")?.IdMoneda ?? 1;
        const idUSD = @monedas.FirstOrDefault(m => m.Codigo == "USD")?.IdMoneda ?? 2;

        // Normalizar saldo a la moneda BASE (NIO) para el cálculo del total cubierto
        let saldoPendienteBase = saldoPendienteOriginal;
        if (codigoCuenta === "USD" && codigoBase === "NIO") {
            saldoPendienteBase = saldoPendienteOriginal * tasa;
        }

        // Badges Dinámicos
        if (codigoBase === "NIO") document.getElementById('badgeBaseNIO').style.display = 'block';
        else document.getElementById('badgeBaseUSD').style.display = 'block';

        if (codigoCuenta === "NIO") document.getElementById('badgeCuentaNIO').style.display = 'block';
        else document.getElementById('badgeCuentaUSD').style.display = 'block';

        if (factorLabel) factorLabel.textContent = `Tasa: ${tasa.toFixed(2)}`;

        function updateCalculations() {
            const montoNio = parseFloat(inputNIO.value) || 0;
            const montoUsd = parseFloat(inputUSD.value) || 0;

            // Normalización de entrada a moneda de la cuenta (para ver si cubre la deuda)
            let nioEnCuenta = 0;
            let usdEnCuenta = 0;

            if (codigoCuenta === "USD") {
                nioEnCuenta = Math.round((montoNio / tasa) * 100) / 100;
                usdEnCuenta = montoUsd;
            } else {
                nioEnCuenta = montoNio;
                usdEnCuenta = Math.round((montoUsd * tasa) * 100) / 100;
            }

            const totalCubierto = Math.round((nioEnCuenta + usdEnCuenta) * 100) / 100;
            
            // Actualizar etiquetas de equivalencia ("Vale")
            const nioEquivUsd = Math.round((montoNio / tasa) * 100) / 100;
            const usdEquivNio = Math.round((montoUsd * tasa) * 100) / 100;

            if (nioEquivLabel) nioEquivLabel.textContent = `$ ${nioEquivUsd.toFixed(2)}`;
            if (usdEquivLabel) usdEquivLabel.textContent = `C$ ${usdEquivNio.toFixed(2)}`;

            // Mostrar total cubierto en la moneda de la cuenta
            const symCuenta = codigoCuenta === "USD" ? "$" : "C$";
            if (totalCubiertoLabel) {
                totalCubiertoLabel.textContent = `${symCuenta} ${totalCubierto.toFixed(2)}`;
                // Color dinámico
                if (totalCubierto >= saldoPendienteOriginal - 0.01) {
                    totalCubiertoLabel.classList.remove('text-danger');
                    totalCubiertoLabel.classList.add('text-primary');
                } else {
                    totalCubiertoLabel.classList.remove('text-primary');
                    totalCubiertoLabel.classList.add('text-danger');
                }
            }

            const restante = Math.round((saldoPendienteOriginal - totalCubierto) * 100) / 100;

            if (restante > 0.01) {
                if (restanteValor) restanteValor.textContent = `${symCuenta} ${restante.toFixed(2)}`;
                if (alertRestante) alertRestante.style.display = 'block';
                if (displayVuelto) displayVuelto.style.display = 'none';
                if (alertInsuficiente) alertInsuficiente.style.display = (montoNio > 0 || montoUsd > 0) ? 'block' : 'none';
                btnSubmit.disabled = true;
            } else {
                if (alertRestante) alertRestante.style.display = 'none';
                if (alertInsuficiente) alertInsuficiente.style.display = 'none';
                btnSubmit.disabled = false;
                
                // Cálculo de Vuelto SIEMPRE en NIO
                let vueltoNio = 0;
                if (codigoCuenta === "USD") {
                    const vueltoUsd = totalCubierto - saldoPendienteOriginal;
                    vueltoNio = Math.round((vueltoUsd * tasa) * 100) / 100;
                } else {
                    vueltoNio = Math.round((totalCubierto - saldoPendienteOriginal) * 100) / 100;
                }

                if (vueltoNio > 0.01 && selectMetodo.value === "EFECTIVO") {
                    if (displayVuelto) displayVuelto.style.display = 'block';
                    if (vueltoValor) vueltoValor.textContent = vueltoNio.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                } else {
                    if (displayVuelto) displayVuelto.style.display = 'none';
                }
            }
        }

        // Listeners
        if (inputNIO) inputNIO.addEventListener('input', updateCalculations);
        if (inputUSD) inputUSD.addEventListener('input', updateCalculations);
        if (selectMetodo) selectMetodo.addEventListener('change', updateCalculations);

        // AJAX Submission
        if (formPago) {
            formPago.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const btn = document.getElementById('btnSubmitPago');
                const originalHtml = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Procesando...';

                const formData = new FormData();
                formData.append('idCuenta', "@Model.IdCuenta");
                formData.append('metodoPago', selectMetodo.value);
                formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                let pIndex = 0;
                // Add NIO payment
                if (parseFloat(inputNIO.value) > 0) {
                    formData.append(`pagos[${pIndex}].IdMoneda`, idNIO);
                    formData.append(`pagos[${pIndex}].Monto`, inputNIO.value);
                    formData.append(`pagos[${pIndex}].MontoRecibido`, inputNIO.value); 
                    pIndex++;
                }

                // Add USD payment
                if (parseFloat(inputUSD.value) > 0) {
                    formData.append(`pagos[${pIndex}].IdMoneda`, idUSD);
                    formData.append(`pagos[${pIndex}].Monto`, inputUSD.value);
                    formData.append(`pagos[${pIndex}].MontoRecibido`, inputUSD.value);
                }

                fetch(formPago.action, {
                    method: 'POST',
                    body: formData
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        const modalEl = document.getElementById('registrarPagoModal');
                        const modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                        modal.hide();
                        MediToast.success(data.message);
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        MediToast.error(data.message);
                        btn.disabled = false;
                        btn.innerHTML = originalHtml;
                    }
                })
                .catch(error => {
                    console.error(error);
                    MediToast.error("Error al procesar el pago");
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                });
            });
        }

        // Anular Cuenta
        const btnAnular = document.getElementById('btnAnularCuenta');
        if (btnAnular) {
            btnAnular.addEventListener('click', function() {
                MediConfirm.show({
                    title: '¿Anular Cuenta permanentemente?',
                    message: 'Esta acción liberará los cargos y devolverá el stock de productos al almacén.',
                    variant: 'danger',
                    confirmText: 'Sí, Anular',
                    icon: 'fa-ban'
                }).then(confirmed => {
                    if (confirmed) {
                        const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]').value;
                        const formData = new FormData();
                        formData.append('id', "@Model.IdCuenta");
                        formData.append('__RequestVerificationToken', csrfToken);

                        fetch('/Caja/AnularCuenta', {
                            method: 'POST',
                            body: formData
                        })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                MediToast.success(data.message);
                                setTimeout(() => location.href = '/Caja/Index', 1500);
                            } else {
                                MediToast.error(data.message);
                            }
                        });
                    }
                });
            });
        }

        updateCalculations();
    });
</script>
}

